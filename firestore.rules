rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.matches('(?i)^(admin|superadmin)[\\s]*$');
    }

    // 1. Users collection
    match /users/{userId} {
      allow create: if isAuth() && request.auth.uid == userId;
      allow read, update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 2. Meetings
    match /meetings/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // 3. Attendance
    match /attendance/{id} {
      allow read, create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // 4. Notifications
    match /notifications/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // 5. Shops & Products
    match /shops/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    match /products/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // 6. Complaints
    match /complaints/{id} {
      allow read, create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // 7. Payments
    match /payments/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Default block for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
